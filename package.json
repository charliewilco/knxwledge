{
	"name": "@charliewilco/knxwledge",
	"version": "2.0.6",
	"license": "Unlicense",
	"type": "module",
	"module": "./dist/index.mjs",
	"typings": "./dist/index.d.mts",
	"engines": {
		"node": ">=24.11.0"
	},
	"files": [
		"dist"
	],
	"sideEffect": false,
	"imports": {
		"#test": "./src/test.ts"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./ds": {
			"types": "./dist/ds.d.mts",
			"import": "./dist/ds.mjs"
		},
		"./js": {
			"types": "./dist/js.d.mts",
			"import": "./dist/js.mjs"
		},
		"./problems": {
			"types": "./dist/problems.d.mts",
			"import": "./dist/problems.mjs"
		},
		"./search": {
			"types": "./dist/search.d.mts",
			"import": "./dist/search.mjs"
		},
		"./sorting": {
			"types": "./dist/sorting.d.mts",
			"import": "./dist/sorting.mjs"
		}
	},
	"scripts": {
		"build": "tsdown --config tsdown.config.ts",
		"test": "node --experimental-transform-types --test \"src/**/*.test.ts\"",
		"coverage": "node --experimental-transform-types --experimental-test-coverage --test \"src/**/*.test.ts\"",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint ./src --log-level=error",
		"format": "biome format --write ./src ./tsdown.config.ts *.json"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@types/node": "^25.9.3",
		"lefthook": "^2.1.8",
		"tsdown": "^0.22.3",
		"typescript": "^6"
	},
	"publishConfig": {
		"@charliewilco:registry": "https://npm.pkg.github.com/"
	},
	"packageManager": "npm@11.5.1"
}
